# MISP instance connection
MISP_URL=https://misp.example.local
MISP_API_KEY=your-misp-api-key
MISP_VERIFY_SSL=true

# Required by ioc_enrich.py
VT_API_KEY=your-virustotal-api-key
ABUSEIPDB_API_KEY=your-abuseipdb-api-key

# Optional, VirusTotal lookup delay in seconds (default: 
# 15s, matches the free-tier limit of 4 requests/minute).
# VT_RATE_LIMIT_DELAY=15